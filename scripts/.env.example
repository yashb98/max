# scripts/.env — Configuration for helper scripts (release / publish scripts).
# Copy this file to scripts/.env and fill in the values.

# SSH host of the Mac mini (required).
# Can include the user, e.g. myuser@192.168.1.50
MAC_MINI_HOST=192.168.1.50

# SSH user for the Mac mini (optional if included in MAC_MINI_HOST above).
MAC_MINI_USER=

# Password for the Mac mini (optional). When set, sshpass is used for SCP/SSH.
MAC_MINI_PASSWORD=

# Path to an SSH private key for the Mac mini (optional).
MAC_MINI_SSH_KEY=

# Intel Mac SSH host (required when using --intel). Can include user, e.g. myuser@192.168.1.51
INTEL_HOST=

# Password for the Intel Mac (optional). When set, sshpass is used for SSH.
INTEL_PASSWORD=

# --- Docker Hub publishing (used by dockerhub-publish.sh) ---

# Docker Hub credentials. When set, the publish script logs in automatically.
DOCKERHUB_USER=
DOCKERHUB_ACCESS_TOKEN=
