{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "allowJs": false,
    "isolatedModules": true,
    "types": []
  },
  "include": [
    "background/**/*.ts",
    "popup/**/*.ts",
    "popup/**/*.tsx",
    "types/**/*.d.ts"
  ],
  "exclude": ["dist/**", "node_modules/**"]
}
