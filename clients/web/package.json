{
  "name": "@vellumai/web",
  "version": "0.8.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "description": "Web interface for the Vellum client (served by `vellum client --interface web`).",
  "exports": {
    ".": "./src/server.ts",
