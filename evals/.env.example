# Simulator LLM API key — required for running tests with the Haiku-backed simulator.
# Used by PR-3+ harness; PR-1 (scaffold) does not invoke any LLM.
ANTHROPIC_API_KEY=

# Optional overrides for definition lookups.
# Defaults to <evals-pkg-dir>/profiles and <evals-pkg-dir>/tests.
# EVALS_PROFILES_DIR=
# EVALS_TESTS_DIR=
