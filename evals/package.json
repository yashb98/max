{
  "name": "@vellumai/evals",
  "version": "0.0.0",
  "description": "Vellum Personal-Intelligence Benchmark harness",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
